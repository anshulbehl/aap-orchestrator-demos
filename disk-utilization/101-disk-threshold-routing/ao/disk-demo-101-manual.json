{
  "triggers": [
    {
      "id": "trigger_manual",
      "type": "manual_trigger",
      "parameters": {
        "input_schema": {
          "type": "object",
          "properties": {
            "disk_mount": {
              "type": "string",
              "default": "/",
              "description": "Filesystem mount to check (e.g. / or /var)"
            }
          }
        }
      }
    }
  ],
  "nodes": [
    {
      "id": "check_disk",
      "type": "aap_job_template",
      "name": "Check Disk Usage",
      "parameters": {
        "verbosity": 0,
        "extra_vars": {
          "disk_mount": "${trigger.disk_mount}"
        },
        "job_template_id": 1
      },
      "settings": {
        "timeout": 1800,
        "retry_policy": {
          "max_retries": 3,
          "max_interval": 60,
          "initial_interval": 5,
          "backoff_coefficient": 2
        }
      },
      "outputs": {
        "job_id": "${result.job_id}",
        "created": "${result.created}",
        "started": "${result.started}",
        "finished": "${result.finished}",
        "artifacts": "${result.artifacts}",
        "job_status": "${result.job_status}"
      }
    },
    {
      "id": "route_disk_tier",
      "type": "switch",
      "name": "Route by disk_tier",
      "parameters": {
        "cases": [
          {
            "port": "ok",
            "label": "<80%",
            "condition": "${check_disk.artifacts.disk_tier} == 'ok'"
          },
          {
            "port": "warn",
            "label": "80-95%",
            "condition": "${check_disk.artifacts.disk_tier} == 'warn'"
          },
          {
            "port": "critical",
            "label": ">95%",
            "condition": "${check_disk.artifacts.disk_tier} == 'critical'"
          }
        ],
        "default_port": "default"
      }
    },
    {
      "id": "remediate_cleanup",
      "type": "aap_job_template",
      "name": "Cleanup Logs",
      "parameters": {
        "verbosity": 0,
        "extra_vars": {
          "disk_mount": "${trigger.disk_mount}",
          "disk_use_percent": "${check_disk.artifacts.disk_use_percent}"
        },
        "job_template_id": 1
      },
      "settings": {
        "timeout": 1800,
        "retry_policy": {
          "max_retries": 3,
          "max_interval": 60,
          "initial_interval": 5,
          "backoff_coefficient": 2
        }
      },
      "outputs": {
        "job_id": "${result.job_id}",
        "job_status": "${result.job_status}",
        "artifacts": "${result.artifacts}"
      }
    },
    {
      "id": "remediate_escalate",
      "type": "aap_job_template",
      "name": "Extend Volume or Page Admin",
      "parameters": {
        "verbosity": 0,
        "extra_vars": {
          "disk_mount": "${trigger.disk_mount}",
          "disk_use_percent": "${check_disk.artifacts.disk_use_percent}"
        },
        "job_template_id": 1
      },
      "settings": {
        "timeout": 1800,
        "retry_policy": {
          "max_retries": 3,
          "max_interval": 60,
          "initial_interval": 5,
          "backoff_coefficient": 2
        }
      },
      "outputs": {
        "job_id": "${result.job_id}",
        "job_status": "${result.job_status}"
      }
    },
    {
      "id": "remediate_fallback",
      "type": "aap_job_template",
      "name": "Unknown Tier Fallback",
      "parameters": {
        "verbosity": 0,
        "extra_vars": {
          "disk_mount": "${trigger.disk_mount}",
          "disk_use_percent": "${check_disk.artifacts.disk_use_percent}"
        },
        "job_template_id": 1
      },
      "settings": {
        "timeout": 1800,
        "retry_policy": {
          "max_retries": 3,
          "max_interval": 60,
          "initial_interval": 5,
          "backoff_coefficient": 2
        }
      },
      "outputs": {
        "job_id": "${result.job_id}",
        "job_status": "${result.job_status}"
      }
    },
    {
      "id": "notify_team",
      "type": "aap_job_template",
      "name": "Notify Team",
      "parameters": {
        "verbosity": 0,
        "extra_vars": {
          "notify_host": "${check_disk.artifacts.notify_host}",
          "disk_mount": "${check_disk.artifacts.disk_mount}",
          "disk_use_percent": "${check_disk.artifacts.disk_use_percent}",
          "disk_tier": "${check_disk.artifacts.disk_tier}",
          "remediation_action": "${check_disk.artifacts.remediation_action}",
          "dnf_cache_removed": "${remediate_cleanup.artifacts.dnf_cache_removed}",
          "log_archives_removed": "${remediate_cleanup.artifacts.log_archives_removed}"
        },
        "job_template_id": 1
      },
      "settings": {
        "timeout": 1800,
        "retry_policy": {
          "max_retries": 3,
          "max_interval": 60,
          "initial_interval": 5,
          "backoff_coefficient": 2
        }
      },
      "outputs": {
        "job_id": "${result.job_id}",
        "job_status": "${result.job_status}"
      }
    }
  ],
  "edges": [
    {
      "from": "trigger_manual",
      "to": "check_disk"
    },
    {
      "from": "check_disk",
      "to": "route_disk_tier"
    },
    {
      "from": "route_disk_tier",
      "to": "notify_team",
      "from_port": "ok"
    },
    {
      "from": "route_disk_tier",
      "to": "remediate_cleanup",
      "from_port": "warn"
    },
    {
      "from": "route_disk_tier",
      "to": "remediate_escalate",
      "from_port": "critical"
    },
    {
      "from": "route_disk_tier",
      "to": "remediate_fallback",
      "from_port": "default"
    },
    {
      "from": "remediate_cleanup",
      "to": "notify_team"
    },
    {
      "from": "remediate_escalate",
      "to": "notify_team"
    },
    {
      "from": "remediate_fallback",
      "to": "notify_team"
    }
  ]
}
