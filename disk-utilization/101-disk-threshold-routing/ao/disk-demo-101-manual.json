{
  "triggers": [
    {
      "id": "trigger_manual",
      "type": "manual_trigger",
      "parameters": {
        "input_schema": {
          "type": "object",
          "properties": {
            "disk_mount": {
              "type": "string",
              "default": "/",
              "description": "Filesystem mount to check (e.g. / or /var)"
            }
          }
        }
      }
    }
  ],
  "nodes": [
    {
      "id": "check_disk",
      "type": "aap_job_template",
      "name": "Check Disk Usage",
      "parameters": {
        "verbosity": 0,
        "extra_vars": {
          "disk_mount": "${trigger.disk_mount}"
        },
        "job_template_id": 115
      },
      "settings": {
        "timeout": 1800,
        "retry_policy": {
          "max_retries": 3,
          "max_interval": 60,
          "initial_interval": 5,
          "backoff_coefficient": 2
        }
      },
      "outputs": {
        "job_id": "${result.job_id}",
        "created": "${result.created}",
        "started": "${result.started}",
        "finished": "${result.finished}",
        "artifacts": "${result.artifacts}",
        "job_status": "${result.job_status}"
      }
    },
    {
      "id": "route_disk_tier",
      "type": "switch",
      "name": "Route by disk_tier",
      "parameters": {
        "cases": [
          {
            "port": "ok",
            "label": "<80%",
            "condition": "${check_disk.artifacts.disk_tier} == 'ok'"
          },
          {
            "port": "warn",
            "label": "80-95%",
            "condition": "${check_disk.artifacts.disk_tier} == 'warn'"
          },
          {
            "port": "critical",
            "label": ">95%",
            "condition": "${check_disk.artifacts.disk_tier} == 'critical'"
          }
        ],
        "default_port": "default"
      }
    },
    {
      "id": "remediate_continue",
      "type": "aap_job_template",
      "name": "Continue",
      "parameters": {
        "verbosity": 0,
        "extra_vars": {
          "disk_mount": "${check_disk.artifacts.disk_mount}",
          "disk_use_percent": "${check_disk.artifacts.disk_use_percent}",
          "disk_tier": "${check_disk.artifacts.disk_tier}"
        },
        "job_template_id": 118
      },
      "settings": {
        "timeout": 1800,
        "retry_policy": {
          "max_retries": 3,
          "max_interval": 60,
          "initial_interval": 5,
          "backoff_coefficient": 2
        }
      },
      "outputs": {
        "job_id": "${result.job_id}",
        "job_status": "${result.job_status}",
        "artifacts": "${result.artifacts}"
      }
    },
    {
      "id": "remediate_cleanup",
      "type": "aap_job_template",
      "name": "Cleanup Logs",
      "parameters": {
        "verbosity": 0,
        "extra_vars": {
          "disk_mount": "${check_disk.artifacts.disk_mount}",
          "disk_use_percent": "${check_disk.artifacts.disk_use_percent}",
          "disk_tier": "${check_disk.artifacts.disk_tier}"
        },
        "job_template_id": 116
      },
      "settings": {
        "timeout": 1800,
        "retry_policy": {
          "max_retries": 3,
          "max_interval": 60,
          "initial_interval": 5,
          "backoff_coefficient": 2
        }
      },
      "outputs": {
        "job_id": "${result.job_id}",
        "job_status": "${result.job_status}",
        "artifacts": "${result.artifacts}"
      }
    },
    {
      "id": "remediate_expand",
      "type": "aap_job_template",
      "name": "Expand EBS Volume",
      "parameters": {
        "verbosity": 0,
        "extra_vars": {
          "disk_mount": "${check_disk.artifacts.disk_mount}",
          "disk_use_percent": "${check_disk.artifacts.disk_use_percent}",
          "disk_tier": "${check_disk.artifacts.disk_tier}"
        },
        "job_template_id": 119
      },
      "settings": {
        "timeout": 1800,
        "retry_policy": {
          "max_retries": 3,
          "max_interval": 60,
          "initial_interval": 5,
          "backoff_coefficient": 2
        }
      },
      "outputs": {
        "job_id": "${result.job_id}",
        "job_status": "${result.job_status}",
        "artifacts": "${result.artifacts}"
      }
    },
    {
      "id": "remediate_fallback",
      "type": "aap_job_template",
      "name": "Unknown Tier Fallback",
      "parameters": {
        "verbosity": 0,
        "extra_vars": {
          "disk_mount": "${check_disk.artifacts.disk_mount}",
          "disk_use_percent": "${check_disk.artifacts.disk_use_percent}",
          "disk_tier": "${check_disk.artifacts.disk_tier}"
        },
        "job_template_id": 120
      },
      "settings": {
        "timeout": 1800,
        "retry_policy": {
          "max_retries": 3,
          "max_interval": 60,
          "initial_interval": 5,
          "backoff_coefficient": 2
        }
      },
      "outputs": {
        "job_id": "${result.job_id}",
        "job_status": "${result.job_status}",
        "artifacts": "${result.artifacts}"
      }
    },
    {
      "id": "notify_team",
      "type": "aap_job_template",
      "name": "Notify Team",
      "parameters": {
        "verbosity": 0,
        "extra_vars": {
          "notify_host": "${remediate_continue.artifacts.notify_host || remediate_cleanup.artifacts.notify_host || remediate_expand.artifacts.notify_host || remediate_fallback.artifacts.notify_host}",
          "disk_mount": "${remediate_continue.artifacts.disk_mount || remediate_cleanup.artifacts.disk_mount || remediate_expand.artifacts.disk_mount || remediate_fallback.artifacts.disk_mount}",
          "disk_use_percent": "${remediate_continue.artifacts.disk_use_percent || remediate_cleanup.artifacts.disk_use_percent || remediate_expand.artifacts.disk_use_percent || remediate_fallback.artifacts.disk_use_percent}",
          "disk_tier": "${remediate_continue.artifacts.disk_tier || remediate_cleanup.artifacts.disk_tier || remediate_expand.artifacts.disk_tier || remediate_fallback.artifacts.disk_tier}",
          "remediation_action": "${remediate_continue.artifacts.remediation_action || remediate_cleanup.artifacts.remediation_action || remediate_expand.artifacts.remediation_action || remediate_fallback.artifacts.remediation_action}",
          "disk_use_percent_before": "${remediate_continue.artifacts.disk_use_percent_before || remediate_cleanup.artifacts.disk_use_percent_before || remediate_expand.artifacts.disk_use_percent_before || remediate_fallback.artifacts.disk_use_percent_before}",
          "disk_use_percent_after": "${remediate_continue.artifacts.disk_use_percent_after || remediate_cleanup.artifacts.disk_use_percent_after || remediate_expand.artifacts.disk_use_percent_after || remediate_fallback.artifacts.disk_use_percent_after}",
          "total_reclaimed_mb": "${remediate_continue.artifacts.total_reclaimed_mb || remediate_cleanup.artifacts.total_reclaimed_mb || remediate_expand.artifacts.total_reclaimed_mb || remediate_fallback.artifacts.total_reclaimed_mb}",
          "dnf_cache_removed": "${remediate_continue.artifacts.dnf_cache_removed || remediate_cleanup.artifacts.dnf_cache_removed || remediate_expand.artifacts.dnf_cache_removed || remediate_fallback.artifacts.dnf_cache_removed}",
          "dnf_cache_freed_mb": "${remediate_continue.artifacts.dnf_cache_freed_mb || remediate_cleanup.artifacts.dnf_cache_freed_mb || remediate_expand.artifacts.dnf_cache_freed_mb || remediate_fallback.artifacts.dnf_cache_freed_mb}",
          "log_archives_removed": "${remediate_continue.artifacts.log_archives_removed || remediate_cleanup.artifacts.log_archives_removed || remediate_expand.artifacts.log_archives_removed || remediate_fallback.artifacts.log_archives_removed}",
          "logs_freed_mb": "${remediate_continue.artifacts.logs_freed_mb || remediate_cleanup.artifacts.logs_freed_mb || remediate_expand.artifacts.logs_freed_mb || remediate_fallback.artifacts.logs_freed_mb}",
          "log_retention_days": "${remediate_continue.artifacts.log_retention_days || remediate_cleanup.artifacts.log_retention_days || remediate_expand.artifacts.log_retention_days || remediate_fallback.artifacts.log_retention_days}",
          "dry_run": "${remediate_continue.artifacts.dry_run || remediate_cleanup.artifacts.dry_run || remediate_expand.artifacts.dry_run || remediate_fallback.artifacts.dry_run}",
          "disk_expand_gb": "${remediate_continue.artifacts.disk_expand_gb || remediate_cleanup.artifacts.disk_expand_gb || remediate_expand.artifacts.disk_expand_gb || remediate_fallback.artifacts.disk_expand_gb}",
          "volume_size_before_gb": "${remediate_continue.artifacts.volume_size_before_gb || remediate_cleanup.artifacts.volume_size_before_gb || remediate_expand.artifacts.volume_size_before_gb || remediate_fallback.artifacts.volume_size_before_gb}",
          "volume_size_after_gb": "${remediate_continue.artifacts.volume_size_after_gb || remediate_cleanup.artifacts.volume_size_after_gb || remediate_expand.artifacts.volume_size_after_gb || remediate_fallback.artifacts.volume_size_after_gb}"
        },
        "job_template_id": 117
      },
      "settings": {
        "timeout": 1800,
        "retry_policy": {
          "max_retries": 3,
          "max_interval": 60,
          "initial_interval": 5,
          "backoff_coefficient": 2
        }
      },
      "outputs": {
        "job_id": "${result.job_id}",
        "job_status": "${result.job_status}"
      }
    }
  ],
  "edges": [
    {
      "from": "trigger_manual",
      "to": "check_disk"
    },
    {
      "from": "check_disk",
      "to": "route_disk_tier"
    },
    {
      "from": "route_disk_tier",
      "to": "remediate_continue",
      "from_port": "ok"
    },
    {
      "from": "route_disk_tier",
      "to": "remediate_cleanup",
      "from_port": "warn"
    },
    {
      "from": "route_disk_tier",
      "to": "remediate_expand",
      "from_port": "critical"
    },
    {
      "from": "route_disk_tier",
      "to": "remediate_fallback",
      "from_port": "default"
    },
    {
      "from": "remediate_continue",
      "to": "notify_team"
    },
    {
      "from": "remediate_cleanup",
      "to": "notify_team"
    },
    {
      "from": "remediate_expand",
      "to": "notify_team"
    },
    {
      "from": "remediate_fallback",
      "to": "notify_team"
    }
  ]
}
