{
  "name": "service-health-switch-demo",
  "description": "Hero demo: check a Linux service and route remediation by service_state (active, inactive, failed, not-found). Import into Automation Orchestrator, then bind each Controller Job step to the matching playbook job template from this repo.",
  "schema_version": "2.0.0",
  "edges": [
    {
      "from": "activity_trigger_service_health",
      "to": "activity_check_service"
    },
    {
      "from": "activity_check_service",
      "to": "activity_switch_service_state"
    },
    {
      "from": "activity_switch_service_state",
      "to": "activity_remediate_log_ok",
      "case": "active"
    },
    {
      "from": "activity_switch_service_state",
      "to": "activity_remediate_start",
      "case": "inactive"
    },
    {
      "from": "activity_switch_service_state",
      "to": "activity_remediate_restart",
      "case": "failed"
    },
    {
      "from": "activity_switch_service_state",
      "to": "activity_remediate_install",
      "case": "not-found"
    }
  ],
  "triggers": [
    {
      "id": "activity_trigger_service_health",
      "name": "Trigger",
      "type": "manual_trigger",
      "config": {
        "inputs": [
          {
            "name": "service_name",
            "type": "string",
            "default": "httpd",
            "description": "systemd unit to check (e.g. httpd, chronyd, sshd)"
          }
        ]
      },
      "position": {
        "x": 0,
        "y": 0
      }
    }
  ],
  "nodes": [
    {
      "id": "activity_check_service",
      "name": "Check Service",
      "type": "controller_job",
      "config": {
        "job_template": "check_service",
        "extra_vars": {
          "service_name": "{{ trigger.service_name }}"
        }
      },
      "settings": {},
      "position": {
        "x": 280,
        "y": 0
      }
    },
    {
      "id": "activity_switch_service_state",
      "name": "Route by service_state",
      "type": "switch",
      "config": {
        "expression": "{{ jobs.check_service.service_state }}",
        "cases": [
          {
            "value": "active",
            "target": "activity_remediate_log_ok"
          },
          {
            "value": "inactive",
            "target": "activity_remediate_start"
          },
          {
            "value": "failed",
            "target": "activity_remediate_restart"
          },
          {
            "value": "not-found",
            "target": "activity_remediate_install"
          }
        ]
      },
      "settings": {},
      "position": {
        "x": 560,
        "y": 0
      }
    },
    {
      "id": "activity_remediate_log_ok",
      "name": "Log OK",
      "type": "controller_job",
      "config": {
        "job_template": "remediate_log_ok",
        "extra_vars": {
          "service_name": "{{ trigger.service_name }}"
        }
      },
      "settings": {},
      "position": {
        "x": 840,
        "y": -120
      }
    },
    {
      "id": "activity_remediate_start",
      "name": "Start Service",
      "type": "controller_job",
      "config": {
        "job_template": "remediate_start_service",
        "extra_vars": {
          "service_name": "{{ trigger.service_name }}"
        }
      },
      "settings": {},
      "position": {
        "x": 840,
        "y": -40
      }
    },
    {
      "id": "activity_remediate_restart",
      "name": "Restart Failed Service",
      "type": "controller_job",
      "config": {
        "job_template": "remediate_restart_service",
        "extra_vars": {
          "service_name": "{{ trigger.service_name }}"
        }
      },
      "settings": {},
      "position": {
        "x": 840,
        "y": 40
      }
    },
    {
      "id": "activity_remediate_install",
      "name": "Install Service",
      "type": "controller_job",
      "config": {
        "job_template": "remediate_install_service",
        "extra_vars": {
          "service_name": "{{ trigger.service_name }}"
        }
      },
      "settings": {},
      "position": {
        "x": 840,
        "y": 120
      }
    }
  ]
}
